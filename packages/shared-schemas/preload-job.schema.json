{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offplanet.cdn/schemas/preload-job",
  "title": "PreloadJobCreate",
  "type": "object",
  "required": ["site_id", "name"],
  "properties": {
    "site_id": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "priority_class_filter": {
      "type": "array",
      "items": { "type": "string", "enum": ["P0","P1","P2","P3","P4","P5"] }
    },
    "bandwidth_budget_bytes": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
