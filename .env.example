# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=offplanet-cdn

# Ollama (optional)
OLLAMA_URL=http://localhost:11434

# Control API
CONTROL_API_URL=http://localhost:8080
CONTROL_API_PORT=8080
JWT_SECRET=dev-secret-change-in-production

# Edge agent
EDGE_AGENT_PORT=8081
EDGE_NODE_ID=local-dev-node
CACHE_DIR=/tmp/offplanet-cache
CACHE_MAX_BYTES=10737418240

# Next.js
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_CONTROL_API_URL=http://localhost:8080
